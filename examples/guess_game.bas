10 PRINT "GUESS GAME!"
20 LET NUMBER = RAND (100)
30 PRINT "GUESS A NUMBER FROM 0 TO 100:"
40 INPUT GUESS
50 IF GUESS > NUMBER THEN 200
60 IF GUESS < NUMBER THEN 400
70 IF GUESS = NUMBER THEN 1100
100 GOTO 1000
200 PRINT "SMALLER!"
210 GOTO 1000
400 PRINT "LARGER!"
410 GOTO 1000
1000 GOTO 30
1100 PRINT "CORRECT!"